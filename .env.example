# ============================================================
# 基金分析系统 - 环境变量配置示例
# 复制此文件为 .env 并填写你的配置
# ============================================================

# ---- AI 大模型 API 配置（由 api_config.yaml 或系统环境变量提供，也可在此覆盖）----
# AI_API_KEY=
# AI_API_BASE=
# AI_MODEL=

# ---- 数据库路径 ----
DATABASE_PATH=fund_analysis.db

# ---- Flask 配置 ----
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True

# ---- 数据拉取配置 ----
# 拉取历史净值天数
FUND_HISTORY_DAYS=365
